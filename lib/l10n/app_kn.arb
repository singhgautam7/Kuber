  "tutCh1St0Desc": "ಒಂದು ನೋಟದಲ್ಲಿ ಈ ತಿಂಗಳ ನೆಟ್ ಫ್ಲೋ. ಹಸಿರು ಬಣ್ಣವು ಆದಾಯ, ಕೆಂಪು ಬಣ್ಣವು ವೆಚ್ಚ. ವಿವರವಾಗಿ ನೋಡಲು ಟ್ಯಾಪ್ ಮಾಡಿ.",
  "tutCh1St1Title": "ಗೌಪ್ಯತೆ ಮೋಡ್",
  "tutCh1St1Desc": "ಪ್ರತಿಯೊಂದು ಬ್ಯಾಲೆನ್ಸ್ ಅನ್ನು ತಕ್ಷಣವೇ ಮರೆಮಾಡಲು ಕಣ್ಣಿನ ಐಕಾನ್ ಟ್ಯಾಪ್ ಮಾಡಿ. ಸಾರ್ವಜನಿಕ ಸ್ಥಳಗಳಿಗೆ ಪರಿಪೂರ್ಣ.",
  "tutCh1St2Title": "ತ್ವರಿತ ಸೇರ್ಪಡೆ",
  "tutCh1St2Desc": "ಪೂರ್ಣ ಫಾರ್ಮ್ ಅನ್ನು ತೆರೆಯದೆ ಸೆಕೆಂಡುಗಳಲ್ಲಿ ವಹಿವಾಟನ್ನು ಲಾಗ್ ಮಾಡಿ. ಕೇವಲ ಟೈಪ್ ಮಾಡಿ ಮತ್ತು ಮುಂದುವರಿಯಿರಿ.",
  "tutCh1St3Title": "ಇತ್ತೀಚಿನ ವಹಿವಾಟುಗಳು",
  "tutCh1St3Desc": "ನಿಮ್ಮ ಕಳೆದ ಕೆಲವು ವಹಿವಾಟುಗಳು ಬ್ಯಾಲೆನ್ಸ್ ಕಾರ್ಡ್‌ನ ಕೆಳಗೆ ಕಾಣಿಸಿಕೊಳ್ಳುತ್ತವೆ. ವೀಕ್ಷಿಸಲು ಅಥವಾ ಸಂಪಾದಿಸಲು ಯಾವುದನ್ನಾದರೂ ಟ್ಯಾಪ್ ಮಾಡಿ.",
  "tutCh1St4Title": "ನ್ಯಾವಿಗೇಶನ್",
  "tutCh1St4Desc": "ಹೋಮ್, ಇತಿಹಾಸ, ಅನಾಲಿಟಿಕ್ಸ್ ಮತ್ತು ಇನ್ನಷ್ಟು ನಡುವೆ ಬದಲಾಯಿಸಲು ಕೆಳಗಿನ ಬಾರ್ ಅನ್ನು ಬಳಸಿ.",
  "tutCh2Title": "ಇತಿಹಾಸ",
  "tutCh2Desc": "ಹಿಂದಿನ ವಹಿವಾಟುಗಳನ್ನು ಹುಡುಕಿ, ಫಿಲ್ಟರ್ ಮಾಡಿ, ಪರಿಶೀಲಿಸಿ ಮತ್ತು ಸಂಪಾದಿಸಿ.",
  "tutCh2St0Title": "ವಹಿವಾಟಿನ ಟೈಮ್‌ಲೈನ್",
  "tutCh2St0Desc": "ನಿಮ್ಮ ಎಲ್ಲಾ ವಹಿವಾಟುಗಳು, ದಿನಾಂಕದ ಪ್ರಕಾರ ಗುಂಪು ಮಾಡಲಾಗಿದೆ. ತೀರಾ ಇತ್ತೀಚಿನದು ಮೇಲ್ಭಾಗದಲ್ಲಿ.",
  "tutCh2St1Title": "ತ್ವರಿತ ಫಿಲ್ಟರ್‌ಗಳು",
  "tutCh2St1Desc": "ಈ ಚಿಪ್‌ಗಳನ್ನು ಬಳಸಿ ಆದಾಯ, ವೆಚ್ಚ ಅಥವಾ ವರ್ಗಾವಣೆಯ ಪ್ರಕಾರ ತ್ವರಿತವಾಗಿ ಫಿಲ್ಟರ್ ಮಾಡಿ.",
  "tutCh2St2Title": "ಸುಧಾರಿತ ಫಿಲ್ಟರ್‌ಗಳು",
  "tutCh2St2Desc": "ದಿನಾಂಕದ ಶ್ರೇಣಿ, ಖಾತೆ, ವರ್ಗ, ಅಥವಾ ಟ್ಯಾಗ್‌ಗಳ ಮೂಲಕ ಏಕಕಾಲದಲ್ಲಿ ಹುಡುಕಲು ಫಿಲ್ಟರ್ ಐಕಾನ್ ಟ್ಯಾಪ್ ಮಾಡಿ.",
  "tutCh2St3Title": "ಸಂಪಾದಿಸಲು ಟ್ಯಾಪ್ ಮಾಡಿ",
  "tutCh2St3Desc": "ಪೂರ್ಣ ವಿವರಗಳನ್ನು ವೀಕ್ಷಿಸಲು, ಕ್ಷೇತ್ರಗಳನ್ನು ಸಂಪಾದಿಸಲು ಅಥವಾ ಅದನ್ನು ಅಳಿಸಲು ಯಾವುದೇ ವಹಿವಾಟನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ.",
  "tutCh3Title": "ಅನಾಲಿಟಿಕ್ಸ್",
  "tutCh3Desc": "ಟ್ರೆಂಡ್‌ಗಳನ್ನು ಗುರುತಿಸಿ ಮತ್ತು ನಿಮ್ಮ ಹಣ ಎಲ್ಲಿಗೆ ಹೋಗುತ್ತದೆ ಎಂಬುದನ್ನು ಅರ್ಥಮಾಡಿಕೊಳ್ಳಿ.",
  "tutCh3St0Title": "ಮೊದಲು ದಿನಾಂಕದ ಶ್ರೇಣಿಯನ್ನು ಹೊಂದಿಸಿ",
  "tutCh3St0Desc": "ಡೀಫಾಲ್ಟ್ ಆಗಿ ಇಂದಿನ ಡೇಟಾವನ್ನು ಮಾತ್ರ ತೋರಿಸಲಾಗುತ್ತದೆ. ಈ ಪಿಲ್ ಅನ್ನು ಟ್ಯಾಪ್ ಮಾಡಿ ಮತ್ತು \"All time\" ಆಯ್ಕೆಮಾಡಿ ಇದರಿಂದ ಕೆಳಗಿನ ಚಾರ್ಟ್‌ಗಳಲ್ಲಿ ಗ್ರಾಫ್ ಮಾಡಲು ಏನಾದರೂ ಇರುತ್ತದೆ.",
  "tutCh3St1Title": "ನಿಮ್ಮ ಹಣಕಾಸಿನ ಸ್ನ್ಯಾಪ್‌ಶಾಟ್",
  "tutCh3St1Desc": "ಪ್ರತಿ ತಿಂಗಳು ನಿಮ್ಮ ಹಣ ಎಲ್ಲಿಗೆ ಹೋಗುತ್ತದೆ ಎಂಬುದರ ದೃಶ್ಯ ವಿಭಜನೆ.",
  "tutCh3St2Title": "ಖರ್ಚಿನ ಟ್ರೆಂಡ್‌ಗಳು",
  "tutCh3St2Desc": "ದೈನಂದಿನ ಖರ್ಚನ್ನು ತೋರಿಸುವ ಬಾರ್ ಚಾರ್ಟ್. 7-ದಿನ ಮತ್ತು ಕಸ್ಟಮ್ ಸಮಯದ ಶ್ರೇಣಿಗಳ ನಡುವೆ ಬದಲಾಯಿಸಿ.",
  "tutCh3St3Title": "ವರ್ಗದ ವಿಭಜನೆ",
  "tutCh3St3Desc": "ಒಂದು ನೋಟದಲ್ಲಿ ಯಾವ ವರ್ಗಗಳು ನಿಮ್ಮ ಬಜೆಟ್ ಅನ್ನು ಹೆಚ್ಚು ಬಳಸುತ್ತವೆ ಎಂಬುದನ್ನು ನೋಡಿ.",
  "tutCh3St4Title": "ಫಿಲ್ಟರ್‌ಗಳು ಮುಂದುವರಿಯುತ್ತವೆ",
  "tutCh3St4Desc": "ಇತಿಹಾಸ ಪುಟದಲ್ಲಿ ನೀವು ಹೊಂದಿಸುವ ಯಾವುದೇ ಫಿಲ್ಟರ್‌ಗಳು ನಿಮ್ಮ ಅನಾಲಿಟಿಕ್ಸ್ ವೀಕ್ಷಣೆಯನ್ನು ಸಹ ನವೀಕರಿಸುತ್ತವೆ.",
  "tutCh4Title": "ಇನ್ನಷ್ಟು ಮತ್ತು ಸೆಟ್ಟಿಂಗ್‌ಗಳು",
  "tutCh4Desc": "Kuber ಅನ್ನು ಕಸ್ಟಮೈಸ್ ಮಾಡಿ, ಡೇಟಾವನ್ನು ನಿರ್ವಹಿಸಿ ಮತ್ತು ಆಳವಾದ ಪರಿಕರಗಳನ್ನು ಅನ್ವೇಷಿಸಿ.",
  "tutCh4St0Title": "ಬಜೆಟ್‌ಗಳು",
  "tutCh4St0Desc": "ಪ್ರತಿ ವರ್ಗಕ್ಕೆ ಮಾಸಿಕ ಖರ್ಚು ಮಿತಿಗಳನ್ನು ಹೊಂದಿಸಿ. Kuber ಸ್ವಯಂಚಾಲಿತವಾಗಿ ನಿಮ್ಮ ಪ್ರಗತಿಯನ್ನು ಟ್ರ್ಯಾಕ್ ಮಾಡುತ್ತದೆ.",
  "tutCh4St1Title": "Kuber ಅನ್ನು ಕೇಳಿ",
  "tutCh4St1Desc": "ನಿಮ್ಮ ಆನ್-ಸಾಧನ AI ಸಹಾಯಕ. ನಿಮ್ಮ ಖರ್ಚಿನ ಬಗ್ಗೆ ಖಾಸಗಿಯಾಗಿ ಪ್ರಶ್ನೆಗಳನ್ನು ಕೇಳಿ.",
  "tutCh4St2Title": "ನಿಮ್ಮ ಡೇಟಾ",
  "tutCh4St2Desc": "CSV ಆಗಿ ರಫ್ತು ಮಾಡಿ, ಬ್ಯಾಕಪ್‌ನಿಂದ ಆಮದು ಮಾಡಿ, ಅಥವಾ ಮಾದರಿ ಡೇಟಾ ರಚಿಸಿ. ಎಲ್ಲವೂ ನಿಮ್ಮ ಸಾಧನದಲ್ಲೇ ಇರುತ್ತದೆ.",

<?xml version="1.0" encoding="utf-8"?>
<!-- Widget outer card: opaque surfaceCard fill, 1dp border, 16dp corners.
     Fully opaque so the widget reads against any wallpaper. -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/kuber_surface_card" />
    <stroke android:width="1dp" android:color="@color/kuber_border" />
    <corners android:radius="16dp" />
</shape>

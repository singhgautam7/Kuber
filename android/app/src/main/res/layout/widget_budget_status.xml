<?xml version="1.0" encoding="utf-8"?>
<!-- Budget Status · 4x3 · 302x224dp. Three budget rows with state-colored bars.
     Each row overlays 3 ProgressBars (primary/amber/expense); the provider shows
     the one matching utilization (portable to API 24, no runtime drawable swap). -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:padding="12dp"
    android:paddingStart="14dp"
    android:paddingEnd="14dp">

    <!-- LOADING -->
    <LinearLayout
        android:id="@+id/state_loading"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:visibility="gone">
        <FrameLayout android:layout_width="100dp" android:layout_height="11dp"
            android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="match_parent" android:layout_height="18dp"
            android:layout_marginTop="16dp" android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="match_parent" android:layout_height="18dp"
            android:layout_marginTop="12dp" android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="match_parent" android:layout_height="18dp"
            android:layout_marginTop="12dp" android:background="@drawable/widget_skeleton_bg" />
    </LinearLayout>

    <!-- EMPTY -->
    <LinearLayout
        android:id="@+id/state_empty"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:visibility="gone">
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/w_budget_status"
            android:textSize="13sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_text_primary" />
        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center">
            <ImageView android:id="@+id/iv_hicon" android:layout_width="24dp" android:layout_height="24dp"
                android:src="@drawable/ic_widget_trending_up" android:contentDescription="@null" />
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:layout_marginTop="8dp" android:text="@string/w_empty_budget_status"
                android:textSize="11sp" android:textColor="@color/kuber_text_muted" />
        </LinearLayout>
    </LinearLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:id="@+id/state_content"
        android:layout_width="match_parent" android:layout_height="match_parent"
        android:orientation="vertical" android:visibility="gone">

        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="@string/w_budget_status"
            android:textSize="13sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_text_primary" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="1dp" android:text="@string/w_this_month_lower"
            android:textSize="10sp" android:textColor="@color/kuber_text_muted" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
            android:layout_weight="1" android:orientation="vertical" android:gravity="center_vertical">

            <!-- row 0 -->
            <LinearLayout android:id="@+id/bud_0" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:paddingTop="5dp" android:paddingBottom="5dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/bud_0_name" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:maxLines="1" android:ellipsize="end" android:text="Food"
                        android:textSize="10.5sp" android:textColor="@color/kuber_text_primary" />
                    <TextView android:id="@+id/bud_0_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₹19,300 / ₹20,000 · 96%"
                        android:textSize="10.5sp" android:textColor="@color/kuber_text_secondary" />
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="5dp"
                    android:layout_marginTop="4dp">
                    <ProgressBar android:id="@+id/bud_0_pb_primary" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_primary" android:visibility="gone" />
                    <ProgressBar android:id="@+id/bud_0_pb_amber" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_amber" android:visibility="gone" />
                    <ProgressBar android:id="@+id/bud_0_pb_expense" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_expense" android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

            <!-- row 1 -->
            <LinearLayout android:id="@+id/bud_1" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:paddingTop="5dp" android:paddingBottom="5dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/bud_1_name" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:maxLines="1" android:ellipsize="end" android:text="Transport"
                        android:textSize="10.5sp" android:textColor="@color/kuber_text_primary" />
                    <TextView android:id="@+id/bud_1_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₹11,900 / ₹15,000 · 79%"
                        android:textSize="10.5sp" android:textColor="@color/kuber_text_secondary" />
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="5dp"
                    android:layout_marginTop="4dp">
                    <ProgressBar android:id="@+id/bud_1_pb_primary" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_primary" android:visibility="gone" />
                    <ProgressBar android:id="@+id/bud_1_pb_amber" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_amber" android:visibility="gone" />
                    <ProgressBar android:id="@+id/bud_1_pb_expense" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_expense" android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>

            <!-- row 2 -->
            <LinearLayout android:id="@+id/bud_2" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:orientation="vertical"
                android:paddingTop="5dp" android:paddingBottom="5dp">
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <TextView android:id="@+id/bud_2_name" android:layout_width="0dp"
                        android:layout_height="wrap_content" android:layout_weight="1"
                        android:maxLines="1" android:ellipsize="end" android:text="Shopping"
                        android:textSize="10.5sp" android:textColor="@color/kuber_text_primary" />
                    <TextView android:id="@+id/bud_2_value" android:layout_width="wrap_content"
                        android:layout_height="wrap_content" android:text="₹9,800 / ₹8,000 · 122%"
                        android:textSize="10.5sp" android:textColor="@color/kuber_text_secondary" />
                </LinearLayout>
                <FrameLayout android:layout_width="match_parent" android:layout_height="5dp"
                    android:layout_marginTop="4dp">
                    <ProgressBar android:id="@+id/bud_2_pb_primary" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_primary" android:visibility="gone" />
                    <ProgressBar android:id="@+id/bud_2_pb_amber" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_amber" android:visibility="gone" />
                    <ProgressBar android:id="@+id/bud_2_pb_expense" style="?android:attr/progressBarStyleHorizontal"
                        android:layout_width="match_parent" android:layout_height="5dp" android:max="100"
                        android:progressDrawable="@drawable/widget_progress_expense" android:visibility="gone" />
                </FrameLayout>
            </LinearLayout>
        </LinearLayout>

        <!-- Footer -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:paddingTop="6dp"
            android:background="@drawable/widget_footer_divider">
            <TextView android:id="@+id/footer_link" android:layout_width="match_parent"
                android:layout_height="wrap_content" android:text="+ 2 more"
                android:textSize="10sp" android:textColor="@color/kuber_text_muted" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>

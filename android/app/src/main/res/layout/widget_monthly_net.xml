<?xml version="1.0" encoding="utf-8"?>
<!-- Monthly Net · 2x2 · 146x146dp. States toggled by the provider. -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:padding="14dp">

    <!-- LOADING -->
    <LinearLayout
        android:id="@+id/state_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">
        <FrameLayout android:layout_width="60dp" android:layout_height="9dp"
            android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="90dp" android:layout_height="20dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="110dp" android:layout_height="8dp"
            android:layout_marginTop="22dp"
            android:background="@drawable/widget_skeleton_bg" />
    </LinearLayout>

    <!-- EMPTY -->
    <LinearLayout
        android:id="@+id/state_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_widget_plus"
            android:contentDescription="@null" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/w_empty_monthly_net"
            android:textSize="10sp"
            android:gravity="center"
            android:textColor="@color/kuber_text_muted" />
    </LinearLayout>

    <!-- CONTENT (also used for stale, dimmed via alpha) -->
    <LinearLayout
        android:id="@+id/state_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="@string/w_this_month"
                android:textAllCaps="true"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/kuber_text_muted" />
            <TextView
                android:layout_width="18dp" android:layout_height="18dp"
                android:background="@drawable/widget_kuber_mark_bg"
                android:gravity="center"
                android:text="@string/w_rupee"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/kuber_primary" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_net"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="+₹18,240"
            android:textSize="26sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="16sp"
            android:autoSizeMaxTextSize="30sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_income" />

        <TextView
            android:id="@+id/tv_subline"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginEnd="52dp"
            android:text="Income ₹64,200 · Expense ₹45,960"
            android:textSize="10sp"
            android:maxLines="2"
            android:textColor="@color/kuber_text_secondary" />
    </LinearLayout>

    <!-- Refresh indicator (bottom-right, stays full opacity when stale) -->
    <LinearLayout
        android:id="@+id/updated_bar"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:visibility="gone">
        <ImageView
            android:id="@+id/iv_stale"
            android:layout_width="9dp" android:layout_height="9dp"
            android:layout_marginEnd="3dp"
            android:src="@drawable/ic_widget_refresh"
            android:contentDescription="@null"
            android:visibility="gone" />
        <TextView
            android:id="@+id/tv_updated"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Updated 4m ago"
            android:textSize="9sp"
            android:textColor="@color/kuber_text_muted" />
    </LinearLayout>
</FrameLayout>

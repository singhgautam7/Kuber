<?xml version="1.0" encoding="utf-8"?>
<!-- Quick Actions · 4x1 · 302x68dp. Four launcher buttons. -->
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:orientation="horizontal"
    android:padding="8dp"
    android:paddingStart="10dp"
    android:paddingEnd="10dp"
    android:baselineAligned="false">

    <LinearLayout android:id="@+id/btn_add_txn" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center">
        <ImageView android:id="@+id/qa_ic_0" android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_widget_plus" android:contentDescription="@null" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:text="@string/w_action_add_txn"
            android:textSize="8.5sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_text_secondary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btn_recurring" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center">
        <ImageView android:id="@+id/qa_ic_1" android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_widget_repeat" android:contentDescription="@null" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:text="@string/w_action_recurring"
            android:textSize="8.5sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_text_secondary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btn_ask_kuber" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center">
        <ImageView android:id="@+id/qa_ic_2" android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_widget_chat" android:contentDescription="@null" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:text="@string/w_action_ask_kuber"
            android:textSize="8.5sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_text_secondary" />
    </LinearLayout>

    <LinearLayout android:id="@+id/btn_import_sms" android:layout_width="0dp"
        android:layout_height="match_parent" android:layout_weight="1"
        android:orientation="vertical" android:gravity="center">
        <ImageView android:id="@+id/qa_ic_3" android:layout_width="16dp" android:layout_height="16dp"
            android:src="@drawable/ic_widget_sms" android:contentDescription="@null" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="3dp" android:text="@string/w_action_import_sms"
            android:textSize="8.5sp" android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_text_secondary" />
    </LinearLayout>
</LinearLayout>

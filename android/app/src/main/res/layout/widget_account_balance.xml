<?xml version="1.0" encoding="utf-8"?>
<!-- Account Balance · 2x2 · 146x146dp -->
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_card_bg"
    android:padding="14dp">

    <!-- LOADING -->
    <LinearLayout
        android:id="@+id/state_loading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">
        <FrameLayout android:layout_width="80dp" android:layout_height="9dp"
            android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="100dp" android:layout_height="18dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/widget_skeleton_bg" />
        <FrameLayout android:layout_width="90dp" android:layout_height="8dp"
            android:layout_marginTop="26dp"
            android:background="@drawable/widget_skeleton_bg" />
    </LinearLayout>

    <!-- EMPTY (unconfigured) -->
    <LinearLayout
        android:id="@+id/state_empty"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <ImageView android:layout_width="20dp" android:layout_height="20dp"
            android:src="@drawable/ic_widget_bank"
            android:contentDescription="@null" />
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/w_empty_account_balance"
            android:textSize="10sp"
            android:gravity="center"
            android:textColor="@color/kuber_text_muted" />
    </LinearLayout>

    <!-- CONTENT -->
    <LinearLayout
        android:id="@+id/state_content"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:visibility="gone">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal">
            <TextView
                android:id="@+id/tv_account_name"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1"
                android:layout_gravity="center_vertical"
                android:maxLines="1"
                android:ellipsize="end"
                android:text="HDFC Savings"
                android:textSize="10sp"
                android:fontFamily="sans-serif-medium"
                android:textColor="@color/kuber_text_muted" />
            <ImageView
                android:layout_width="18dp" android:layout_height="18dp"
                android:layout_marginStart="6dp"
                android:background="@drawable/widget_account_icon_bg"
                android:contentDescription="@null" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_balance"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="center_vertical"
            android:text="₹2,84,650"
            android:textSize="22sp"
            android:maxLines="1"
            android:autoSizeTextType="uniform"
            android:autoSizeMinTextSize="14sp"
            android:autoSizeMaxTextSize="24sp"
            android:fontFamily="sans-serif-medium"
            android:textColor="@color/kuber_income" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:gravity="center_vertical"
            android:orientation="horizontal">
            <ImageView
                android:id="@+id/iv_stale"
                android:layout_width="9dp" android:layout_height="9dp"
                android:layout_marginEnd="3dp"
                android:src="@drawable/ic_widget_refresh"
                android:contentDescription="@null"
                android:visibility="gone" />
            <TextView
                android:id="@+id/tv_updated"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="Last updated 4m ago"
                android:textSize="10sp"
                android:textColor="@color/kuber_text_secondary" />
        </LinearLayout>
    </LinearLayout>
</FrameLayout>
